{
  "expo": {
    "name": "SafeLocker",
    "slug": "safelocker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Safelocker2.png",
    "userInterfaceStyle": "automatic",
    "scheme": "safelocker",
    "splash": {
      "image": "./assets/Safelocker2.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sheikhtaj.safelocker"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Safelocker2.png",
        "backgroundColor": "#121212"
      },
      "package": "com.sheikhtaj.safelocker",
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "plugins": [
      "expo-font",
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow SafeLocker to use Biometrics for secure unlocking."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SafeLocker to access camera for scanning QR codes."
        }
      ],
      "expo-image-picker",
      "expo-document-picker",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow SafeLocker to access photos for secure vault storage.",
          "savePhotosPermission": "Allow SafeLocker to save exported photos back to gallery."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "4f4f6b00-5e25-46eb-9397-c36bee889a1c"
      }
    }
  }
}
